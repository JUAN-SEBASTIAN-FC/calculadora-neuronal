{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/data/**",
              "components/feedback/**",
              "components/forms/**",
              "ui_kits/converge-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Space Grotesk|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Space Grotesk, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|title|children|icon|className|key|ref|className|style|children)$/]",
        "message": "<Alert> doesn't accept that prop. Declared props: variant, title, children, icon, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:danger|warning|info|success)$/]",
        "message": "<Alert> variant must be one of 'danger' | 'warning' | 'info' | 'success'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:color|solid|mono|dot|children|className|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: color, solid, mono, dot, children, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|iconRight|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, iconRight, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|title|actions|children|bodyClassName|className|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: variant, title, actions, children, bodyClassName, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|variant|size|active|label|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: icon, variant, size, active, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|prefix|suffix|monoLabel|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, error, prefix, suffix, monoLabel."
      },
      {
        "selector": "JSXOpeningElement[name.name='IterationRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:n|x|fx|absError|relError|converged|key|ref|className|style|children)$/]",
        "message": "<IterationRow> doesn't accept that prop. Declared props: n, x, fx, absError, relError, converged."
      },
      {
        "selector": "JSXOpeningElement[name.name='NumberField'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|value|onChange|step|min|max|suffix|className|key|ref|className|style|children)$/]",
        "message": "<NumberField> doesn't accept that prop. Declared props: label, hint, error, value, onChange, step, min, max, suffix, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='SelectOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SelectOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Slider'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|min|max|step|onChange|format|className|key|ref|className|style|children)$/]",
        "message": "<Slider> doesn't accept that prop. Declared props: label, value, min, max, step, onChange, format, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|status|key|ref|className|style|children)$/]",
        "message": "<StatPill> doesn't accept that prop. Declared props: label, value, status."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatPill'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:default|success|running)$/]",
        "message": "<StatPill> status must be one of 'default' | 'success' | 'running'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|label|id|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, onChange, label, id."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|icon|accent|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: value, label, icon, accent."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:bisection|newton)$/]",
        "message": "<TabItem> accent must be one of 'bisection' | 'newton'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tooltip'] > JSXAttribute > JSXIdentifier[name!=/^(?:content|shortcut|children|key|ref|className|style|children)$/]",
        "message": "<Tooltip> doesn't accept that prop. Declared props: content, shortcut, children."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
